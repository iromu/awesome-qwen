{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Qwen Agent",
  "description": "Schema for Qwen Code agent definition files",
  "type": "object",
  "required": ["name", "description"],
  "properties": {
    "name": {
      "type": "string",
      "description": "Human-readable name of the agent",
      "minLength": 1,
      "maxLength": 128
    },
    "description": {
      "type": "string",
      "description": "Brief description of what the agent does",
      "minLength": 10,
      "maxLength": 512
    },
    "model": {
      "type": "string",
      "description": "Recommended model for this agent",
      "enum": ["qwen-max", "qwen-plus", "qwen-turbo", "qwen-coder"]
    },
    "tools": {
      "type": "array",
      "description": "List of tools this agent has access to",
      "items": {
        "type": "string"
      }
    },
    "tags": {
      "type": "array",
      "description": "Categorization tags",
      "items": {
        "type": "string"
      }
    },
    "category": {
      "type": "string",
      "description": "Primary category",
      "enum": ["development", "debugging", "testing", "devops", "security", "documentation", "data", "frontend", "backend", "mobile"]
    },
    "instructions": {
      "type": "string",
      "description": "Full agent instructions and behavior definition"
    }
  },
  "additionalProperties": false
}
